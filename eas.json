{
  "cli": {
    "version": ">= 7.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "simulator": false
      }
    },
    "testflight_fresh": {
      "extends": "production",
      "distribution": "store"
    }
  },
  "submit": {
    "production": {}
  }
}
